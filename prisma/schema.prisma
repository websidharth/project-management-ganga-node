generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HALF_DAY
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  ONLINE
}

enum Status {
  Published
  Draft
  Trash
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model users {
  id                       Int               @id @default(autoincrement())
  userId                   String            @unique // public/business id
  name                     String
  userName                 String            @unique
  phone                    String?
  email                    String            @unique
  password                 String
  role                     Role              @default(USER)
  isActive                 Boolean           @default(false)
  isRegisterbyShop         Boolean           @default(false)
  isEmailVerified          Boolean           @default(false)
  emailVerificationToken   String?           @unique
  emailVerificationExpires DateTime?
  isPhoneVerified          Boolean           @default(false)
  profileImageUrl          String?
  loginAttempts            Int               @default(0)
  lastLoginAt              DateTime?
  lastLoginIP              String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime?         @updatedAt
  status                   Status            @default(Published)
  token                    String?
  tokenUpdated             Boolean           @default(false)
  refreshToken             String?
  metadata                 Json?
  storeCode                String?
  profile                  userProfile?
  productsCreated          product[]         @relation("CreatedBy")
  productsUpdated          product[]         @relation("UpdatedBy")
  orders                   order[] // customer orders placed by this user
  staffAttendances         staffAttendance[] @relation("staff_member")
  recordedAttendances      staffAttendance[] @relation("staff_attendance_recorder")
  staffSalaries            staffSalary[]     @relation("salary_staff")
  processedSalaries        staffSalary[]     @relation("salary_processor")
  store                    store?            @relation(fields: [storeCode], references: [code])
  staff                    staff?

  @@index([userId])
  @@index([email])
  @@index([phone])
  @@index([role])
}

model userProfile {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  phone       String?
  email       String    @unique
  user        users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth DateTime?
  address     String?
  city        String?
  state       String?
  pincode     String?
  bio         String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model store {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  code              String             @unique
  address           String?
  phone             String?
  email             String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  status            Status             @default(Published)
  // Relations
  categories        category[]
  brandNames        brandName[]
  attributes        attribute[]
  Product           product[]
  orders            order[]
  orderItems        orderItem[]
  payments          payment[]
  staff             users[] // employees of this store
  staffAttendances  staffAttendance[]
  staffSalary       staffSalary[]
  staffDetails      staff[]
}

// ========== PRODUCT MANAGEMENT ==========
model category {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?
  parentId     Int?
  storeCode    String
  status       Status      @default(Published)
  displayOrder Int?        @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  parent       category?   @relation("CategoryToParent", fields: [parentId], references: [id])
  children     category[]  @relation("CategoryToParent")
  products     product[]
  brandNames   brandName[]
  store        store?      @relation(fields: [storeCode], references: [code])

  @@unique([name, storeCode])
  @@index([storeCode])
}

model product {
  id                Int      @id @default(autoincrement())
  name              String
   parentId   Int?
  categoryId        Int
  brandNameId       Int?
attributeId Int?
attribute   attribute? @relation(fields: [attributeId], references: [id])
  slug              String   @unique
  description       String?
  price             Float    @default(0)
  cost              Float?
  stock             Int      @default(0)
  lowStockThreshold Int?     @default(5)
  images            String[]  @default([])
  storeCode         String
  status            Status   @default(Published)
  displayOrder      Int?     @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdById       String
  updatedById       String?



  parent     product?  @relation("ProductHierarchy", fields: [parentId], references: [id])
  children   product[] @relation("ProductHierarchy")

  brandName  brandName?         @relation(fields: [brandNameId], references: [id])
  store      store?             @relation(fields: [storeCode], references: [code])
  createdBy  users              @relation("CreatedBy", fields: [createdById], references: [userId])
  updatedBy  users?             @relation("UpdatedBy", fields: [updatedById], references: [userId])
  orderItems orderItem[]
  category   category           @relation(fields: [categoryId], references: [id])
}

model brandName {
  id             Int              @id @default(autoincrement())
  brandName      String
  storeCode      String
  status         Status           @default(Published)
  displayOrder   Int?             @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  product        product[]
  categories     category[]
  store          store?           @relation(fields: [storeCode], references: [code])

  @@unique([brandName, storeCode])
  @@index([id])
  @@index([storeCode])
}

model attribute {
  id                Int                @id @default(autoincrement())
  name              String
  unit              String?
  storeCode         String
  status            Status             @default(Published)
  displayOrder      Int?               @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  store             store?             @relation(fields: [storeCode], references: [code])
  products    product[]
  @@unique([name, storeCode])
  @@index([id])
  @@index([storeCode])
}

model staff {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  storeCode  String
  position   String? // Job title/position
  department String?
  hireDate   DateTime @default(now())
  salary     Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  users @relation(fields: [userId], references: [id], onDelete: Cascade)
  store store @relation(fields: [storeCode], references: [code])

  @@index([userId])
  @@index([storeCode])
  @@index([isActive])
}

// ========== STAFF ATTENDANCE ==========
model staffAttendance {
  id            Int              @id @default(autoincrement())
  staffId       Int
  date          DateTime         @map("date") // attendance date (date only, time truncated)
  status        AttendanceStatus @default(PRESENT)
  checkInTime   DateTime?
  checkOutTime  DateTime?
  overtimeHours Float? // in hours
  remarks       String?
  recordedBy    Int? // staff ID who marked attendance (optional)
  storeCode     String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  staff    users  @relation("staff_member", fields: [staffId], references: [id], onDelete: Cascade)
  recorder users? @relation("staff_attendance_recorder", fields: [recordedBy], references: [id])
  store    store  @relation(fields: [storeCode], references: [code])

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
}

// ========== ORDER & PAYMENT (Product Sales) ==========
model order {
  id           Int         @id @default(autoincrement())
  orderNumber  String      @unique
  customerId   Int // user who placed order
  orderDate    DateTime    @default(now())
  totalAmount  Float       @default(0)
  discount     Float       @default(0)
  tax          Float       @default(0)
  shippingCost Float       @default(0)
  grandTotal   Float       @default(0)
  status       OrderStatus @default(PENDING)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  customer     users       @relation(fields: [customerId], references: [id])
  items        orderItem[]
  payments     payment[]
  store        store       @relation(fields: [storeCode], references: [code])
  storeCode    String

  @@index([customerId])
  @@index([orderNumber])
  @@index([status])
}

model orderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  productId  Int
  variantId  Int? // optional, if a specific variant was chosen
  storeCode  String
  quantity   Int
  unitPrice  Float // price at time of purchase
  totalPrice Float
  createdAt  DateTime @default(now())

  order   order           @relation(fields: [orderId], references: [id])
  product product         @relation(fields: [productId], references: [id])

  store   store           @relation(fields: [storeCode], references: [code])

  @@index([orderId])
  @@index([productId])
  @@index([storeCode])
}

model payment {
  id            Int           @id @default(autoincrement())
  orderId       Int
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique
  paymentDate   DateTime      @default(now())
  remarks       String?
  storeCode     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order order @relation(fields: [orderId], references: [id])
  store store @relation(fields: [storeCode], references: [code])

  @@index([orderId])
  @@index([transactionId])
  @@index([paymentDate])
  @@index([storeCode])
}

// ========== STAFF SALARY ==========
model staffSalary {
  id               Int           @id @default(autoincrement())
  staffId          Int
  month            Int // 1-12
  year             Int
  baseSalary       Float // fixed monthly salary
  attendanceBonus  Float? // extra based on attendance
  deductions       Float? // for leaves, late arrivals, etc.
  advanceDeduction Float? // any salary advance given
  netPayable       Float
  paidAmount       Float         @default(0)
  status           PaymentStatus @default(PENDING)
  paymentDate      DateTime?
  remarks          String?
  processedBy      Int? // admin/staff who processed salary
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  storeCode        String
  store            store         @relation(fields: [storeCode], references: [code])
  staff            users         @relation("salary_staff", fields: [staffId], references: [id])
  processor        users?        @relation("salary_processor", fields: [processedBy], references: [id])

  @@unique([staffId, month, year])
  @@index([staffId])
  @@index([status])
  @@index([month, year])
}
